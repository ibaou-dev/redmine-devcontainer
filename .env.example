# .env.example
# Copy to .env and customize. .env is git-ignored — never commit it.
#
#   cp .env.example .env

# --- Compose project isolation ---
# Set a unique name per worktree to avoid container/network name collisions.
# Docker prefixes all container, network, and volume names with this value.
COMPOSE_PROJECT_NAME=redmine-dev

# --- Port configuration ---
# Main development port (local mode)
REDMINE_PORT=4000
# Test / CI / DevContainer port
TEST_REDMINE_PORT=4001

# --- Traefik (only needed with docker-compose.yml + Traefik proxy) ---
TRAEFIK_HOST=redmine.int.sumsol.gr

# --- Database ---
POSTGRES_PASSWORD=password

# --- Redmine ---
REDMINE_SECRET_KEY_BASE=development_secret_key_base

# --- Reference source version ---
# Used by scripts/init-references.sh to clone the correct Redmine tag
REDMINE_VERSION=6.1.1
