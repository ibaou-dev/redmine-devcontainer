# ─────────────────────────────────────────────────────────────
#  Redmine Development Environment — Environment Configuration
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# SECURITY: .env is git-ignored. Never commit it.
# The defaults below are for local development ONLY.
# Change POSTGRES_PASSWORD and REDMINE_SECRET_KEY_BASE before
# exposing this environment to any network.
# ─────────────────────────────────────────────────────────────

# Docker Compose project name — must be unique per worktree.
COMPOSE_PROJECT_NAME=redmine-dev

# Port Redmine listens on in local/Traefik mode.
REDMINE_PORT=4000

# Port Redmine listens on in test/CI/DevContainer mode.
TEST_REDMINE_PORT=4001

# Hostname for Traefik routing (only used with: make start-traefik).
TRAEFIK_HOST=redmine.localhost

# PostgreSQL password — change for any shared/networked environment.
POSTGRES_PASSWORD=change_me_in_production

# Rails secret key base — change for any shared/networked environment.
REDMINE_SECRET_KEY_BASE=development_secret_key_base_change_me

# Redmine version — controls the base Docker image tag AND the source
# cloned by `make references`. Must match an official redmine: image tag.
REDMINE_VERSION=6.1.1

# Redmine system API key — required only if you use the repo-sync
# service (git repository mirroring). Leave blank to disable the
# changeset fetch. Set this to your Redmine system API key
# (Administration > Settings > Repositories > API key).
# REDMINE_API_KEY=
